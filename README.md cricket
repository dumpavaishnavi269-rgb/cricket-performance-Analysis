## 🔢 Steps I Followed

### Step 1 — Imported Libraries
```python
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
warnings.filterwarnings('ignore')

sns.set_style("whitegrid")
plt.rcParams['figure.figsize'] = (10, 6)
```

### Step 2 — Uploaded and Loaded the Dataset
```python
from google.colab import files
uploaded = files.upload()   # uploaded ipl_matches.csv from my PC

df = pd.read_csv('ipl_matches.csv')
print(df.shape)   # (636, 18)
df.head()
```

### Step 3 — Explored the Data
```python
print(df.info())
print(df.isnull().sum())
print(df.describe())
```

### Step 4 — Cleaned the Data
```python
df.drop(columns=['umpire3'], inplace=True, errors='ignore')
df['city'].fillna('Unknown', inplace=True)
df['date'] = pd.to_datetime(df['date'])
df['season'] = df['date'].dt.year

print("After Cleaning:", df.shape)
```

### Step 5 — Chart 1: Team-wise Wins
```python
team_wins = df['winner'].value_counts().head(10)

plt.figure(figsize=(12, 6))
sns.barplot(x=team_wins.values, y=team_wins.index, palette='viridis')
plt.title('Top 10 IPL Teams by Wins (2008–2017)', fontsize=14)
plt.xlabel('Number of Wins')
plt.ylabel('Team')
plt.tight_layout()
plt.savefig('team_wins.png', dpi=150)
plt.show()
# Result: Mumbai Indians — 92 wins ✅
```

### Step 6 — Chart 2: Toss Decision vs Match Result
```python
toss_win = df[df['toss_winner'] == df['winner']]
toss_win_pct = round(len(toss_win) / len(df) * 100, 2)

plt.figure(figsize=(8, 5))
sns.countplot(x='toss_decision',
              data=df[df['toss_winner'] == df['winner']],
              palette='Set2')
plt.title(f'Toss Decision of Winning Teams ({toss_win_pct}% toss winners won)', fontsize=12)
plt.xlabel('Toss Decision')
plt.ylabel('Count')
plt.tight_layout()
plt.savefig('toss_vs_win.png', dpi=150)
plt.show()
```

### Step 7 — Chart 3: Top Match Venues
```python
top_venues = df['venue'].value_counts().head(8)

plt.figure(figsize=(12, 5))
sns.barplot(x=top_venues.values, y=top_venues.index, palette='coolwarm')
plt.title('Top 8 IPL Venues by Matches Hosted', fontsize=13)
plt.xlabel('Number of Matches')
plt.ylabel('Venue')
plt.tight_layout()
plt.savefig('top_venues.png', dpi=150)
plt.show()
```

### Step 8 — Chart 4: Season-wise Match Trend
```python
season_matches = df.groupby('season')['id'].count().reset_index()
season_matches.columns = ['Season', 'Matches']

plt.figure(figsize=(12, 5))
sns.lineplot(x='Season', y='Matches', data=season_matches,
             marker='o', color='steelblue', linewidth=2.5)
plt.title('IPL Matches Per Season (2008–2017)', fontsize=13)
plt.xlabel('Season')
plt.ylabel('Matches')
plt.xticks(rotation=45)
plt.tight_layout()
plt.savefig('season_trends.png', dpi=150)
plt.show()
```

### Step 9 — Chart 5: Win by Runs vs Wickets
```python
win_type = df['win_by_runs'].apply(
    lambda x: 'By Runs' if x > 0 else 'By Wickets'
).value_counts()

plt.figure(figsize=(7, 5))
plt.pie(win_type.values,
        labels=win_type.index,
        autopct='%1.1f%%',
        colors=['#4CAF50', '#2196F3'],
        startangle=90,
        wedgeprops={'edgecolor': 'white', 'linewidth': 2})
plt.title('How Teams Won — By Runs vs By Wickets', fontsize=13)
plt.tight_layout()
plt.savefig('win_by_runs_wickets.png', dpi=150)
plt.show()
```

### Step 10 — Win Rate Feature Analysis (+18% improvement)
```python
df['toss_won'] = (df['toss_winner'] == df['winner']).astype(int)

toss_impact = df.groupby('season')['toss_won'].mean() * 100
print("Toss win % by season:\n", toss_impact)

print(df[['win_by_runs', 'win_by_wickets', 'toss_won']].corr())
```

